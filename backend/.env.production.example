# Production Environment Variables
# Copy this file to .env.production and update the values

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# JWT Secret (generate a strong secret key)
JWT_SECRET=your_jwt_secret_key_min_32_characters_long_for_security

# Application Ports (optional - defaults are set in docker-compose)
# API Gateway runs on ports 80 and 443

# Optional: Domain name (for SSL configuration)
# DOMAIN_NAME=yourdomain.com

# Optional: Email configuration for notifications
# SPRING_MAIL_HOST=smtp.gmail.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=your-email@gmail.com
# SPRING_MAIL_PASSWORD=your-app-password

# Optional: Logstash (if using centralized logging)
# LOGSTASH_HOST=logstash
# LOGSTASH_PORT=5000
